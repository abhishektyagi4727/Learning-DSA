
public class LinkedList
{
	private Node head;
	public LinkedList(int element)
	{
		Node newNode=new Node(element);
		head=null;
	}
	//Method to add a node in a linked list
	public boolean add(int element)
	{
		Node newNode=new Node(element);
		if(head==null)
		{
			head=newNode;
			newNode.next=null;
			return true;
		}
		else
		{
			Node current=head;
			while(current.next!=null)
			{
				current.next=newNode;
				newNode.next=null;
			}
			System.out.println("New Node Is Added from "+newNode.data);
		}
		return false;
		
	}
	
}
