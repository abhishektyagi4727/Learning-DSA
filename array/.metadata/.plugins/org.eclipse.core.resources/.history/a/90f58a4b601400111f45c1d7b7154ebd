
public class GetLargestNumber {
	static int getLargestNumber(int arr[])
	{
		int largest=arr[0];
		for(int i=1;i<arr.length;i++)
		{
			if(arr[i]>arr[i+1])
			{
				largest=arr[i];
			}
		}
		return largest;
		
	}

	public static void main(String[] args) 
	{
		int arr[]= {34,54,22,78,45,67};
		GetLargestNumber.getLargestNumber(arr);
	}

}
